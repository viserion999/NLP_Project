
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# For Local MongoDB:
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.yp4hidy.mongodb.net/MERGE_APP

# Secret key for JWT token generation (change in production)
#(any random string, ideally at least 32 characters long)
SECRET_KEY=secret_key_here

# CORS Configuration
# Development mode (allows common dev ports):
ALLOWED_ORIGINS=dev

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SMTP Email Configuration for OTP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your email credentials
SMTP_USER=smtp_user_here
SMTP_PASSWORD=smtp_password_here

# Email sender details (optional, defaults to SMTP_USER)
SMTP_FROM_EMAIL=sender_email_here
SMTP_FROM_NAME=LyricMind

# OTP Configuration (optional)
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ML Model Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# For hugging face API token (optional, for faster inference and higher rate limits)
HF_API_TOKEN=huggingface_api_token_here
